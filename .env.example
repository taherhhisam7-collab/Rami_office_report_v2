# Neon PostgreSQL connection URL. Keep the real value only in your host's
# encrypted environment-variable settings; never commit it to Git.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
OAUTH_SERVER_URL=https://your-app.onrender.com
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=your-admin-email@example.com

# OAuth application credentials for the manager login. In Google Cloud, add
# ${OAUTH_SERVER_URL}/api/oauth/google/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# JSON for the Google service account that has Viewer access to the four source
# spreadsheets. Put the complete JSON on one line when configuring your host.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
